# Example environment variables for Taso development
# Copy this file to .env and fill in your actual values
# IMPORTANT: Never commit .env to version control!

# Taso configuration
TASO_CACHE_DIR=.taso
TASO_AUDIT_LOG=.taso/audit.log
TASO_MAX_FILE_SIZE=52428800
TASO_SCAN_TIMEOUT=300

# For CI/CD integration
CI_ENVIRONMENT=false
ENABLE_JSON_OUTPUT=false

# For future integrations (Phase 2+)
VAULT_ADDR=
VAULT_TOKEN=
SLACK_WEBHOOK_URL=
GITHUB_TOKEN=

USER=
USERNAME=
